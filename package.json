{
  "name": "clwnd",
  "version": "0.21.6",
  "description": "clwnd - take back what is yours",
  "type": "module",
  "private": true,
  "workspaces": [
    "plugins/*"
  ],
  "main": "dist/daemon/index.js",
  "exports": {
    ".": {
      "import": "./dist/daemon/index.js",
      "types": "./dist/daemon/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && pnpm -r run build",
    "build:daemon": "tsup",
    "build:plugins": "pnpm -r run build",
    "test": "vitest run",
    "test:e2e-serve": "vitest run tests/e2e-serve.test.ts",
    "dev": "tsup --watch",
    "tc": "tsc --noEmit",
    "version:patch": "bun run scripts/version.sh patch",
    "version:minor": "bun run scripts/version.sh minor",
    "version:major": "bun run scripts/version.sh major"
  },
  "keywords": [
    "opencode",
    "claude",
    "cli",
    "daemon",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adiled/clwnd.git"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "bun-types": "^1.3.11",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.5",
    "better-sqlite3": "^12.9.0",
    "diff": "^8.0.3",
    "tree-sitter": "0.21.1",
    "tree-sitter-bash": "0.23.3",
    "tree-sitter-c": "0.23.6",
    "tree-sitter-c-sharp": "0.23.1",
    "tree-sitter-cpp": "0.23.4",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-php": "0.23.12",
    "tree-sitter-python": "0.23.6",
    "tree-sitter-ruby": "0.23.1",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-typescript": "0.23.2",
    "web-tree-sitter": "0.25.0"
  }
}
