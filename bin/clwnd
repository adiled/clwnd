#!/usr/bin/env bash
set -e

XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
CLWND_SRC="$XDG_DATA_HOME/clwnd/src"

if [ ! -d "$CLWND_SRC" ]; then
  echo "clwnd not installed. Run:"
  echo "  curl -fsSL https://raw.githubusercontent.com/adiled/clwnd/main/install | bash"
  exit 1
fi

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  update)
    exec bash -c "$(curl -fsSL "https://raw.githubusercontent.com/adiled/clwnd/main/install?t=$(date +%s)")" -- update
    ;;
  force)
    exec bash -c "$(curl -fsSL "https://raw.githubusercontent.com/adiled/clwnd/main/install?t=$(date +%s)")" -- install
    ;;
  uninstall)
    exec bash -c "$(curl -fsSL "https://raw.githubusercontent.com/adiled/clwnd/main/install?t=$(date +%s)")" -- uninstall
    ;;
  status)
    IS_ROOT=$([ "$(id -u)" = "0" ] && echo true || echo false)
    SC="systemctl"
    $IS_ROOT || SC="systemctl --user"
    OS="$(uname -s)"

    if [ "$OS" = "Darwin" ]; then
      # Capture launchctl output first — piping directly to head swallows
      # the failure exit code so the `|| echo "daemon not running"` branch
      # would never fire. Do it in two steps so we can tell them apart.
      OUT=$(launchctl print "gui/$(id -u)/com.clwnd.daemon" 2>&1)
      if [ $? -eq 0 ]; then
        echo "$OUT" | head -5
      else
        echo "daemon not running (launchctl: $OUT)"
      fi
    else
      if $SC is-active --quiet clwnd; then
        $SC status clwnd 2>/dev/null | head -5
      else
        echo "daemon not running"
      fi
    fi
    ;;
  doctor)
    OS="$(uname -s)"
    XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}"
    echo "clwnd doctor"
    echo "  os:         $OS"
    echo "  version:    $(cat "$CLWND_SRC/package.json" | grep '"version"' | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/')"
    echo "  src:        $CLWND_SRC ($(cd "$CLWND_SRC" && git describe --tags --exact-match 2>/dev/null || echo 'not a tag'))"
    echo
    echo "── process ──"
    PIDS=$(pgrep -f "dist/daemon/index.js" 2>/dev/null || true)
    if [ -n "$PIDS" ]; then
      ps -o pid,user,etime,command -p $PIDS 2>/dev/null || true
    else
      echo "  no daemon process found"
    fi
    echo
    echo "── port 29147 ──"
    if command -v lsof >/dev/null 2>&1; then
      lsof -iTCP:29147 -sTCP:LISTEN 2>/dev/null || echo "  nothing listening"
    elif command -v ss >/dev/null 2>&1; then
      ss -tlnp 2>/dev/null | grep 29147 || echo "  nothing listening"
    else
      echo "  (no lsof/ss available)"
    fi
    echo
    echo "── service ──"
    if [ "$OS" = "Darwin" ]; then
      PLIST="$HOME/Library/LaunchAgents/com.clwnd.daemon.plist"
      if [ -f "$PLIST" ]; then
        echo "  plist:      $PLIST (exists)"
      else
        echo "  plist:      $PLIST (MISSING — run: clwnd update)"
      fi
      if launchctl print "gui/$(id -u)/com.clwnd.daemon" >/dev/null 2>&1; then
        echo "  launchctl:  loaded"
      else
        echo "  launchctl:  NOT loaded (run: clwnd restart)"
      fi
      STDOUT_LOG="$XDG_STATE_HOME/clwnd/daemon.stdout.log"
      STDERR_LOG="$XDG_STATE_HOME/clwnd/daemon.stderr.log"
      for f in "$STDOUT_LOG" "$STDERR_LOG"; do
        if [ -f "$f" ]; then
          SIZE=$(wc -c < "$f" 2>/dev/null | tr -d ' ')
          MTIME=$(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "$f" 2>/dev/null || stat -c '%y' "$f" 2>/dev/null)
          echo "  $(basename "$f"): ${SIZE}B  (modified $MTIME)"
        else
          echo "  $(basename "$f"): missing"
        fi
      done
    else
      IS_ROOT=$([ "$(id -u)" = "0" ] && echo true || echo false)
      SC="systemctl"
      $IS_ROOT || SC="systemctl --user"
      UNIT_FILE="$HOME/.config/systemd/user/clwnd.service"
      $IS_ROOT && UNIT_FILE="/etc/systemd/system/clwnd.service"
      if [ -f "$UNIT_FILE" ]; then
        echo "  unit:       $UNIT_FILE (exists)"
      else
        echo "  unit:       $UNIT_FILE (MISSING)"
      fi
      if $SC is-active --quiet clwnd 2>/dev/null; then
        echo "  systemd:    active"
      else
        echo "  systemd:    not active"
      fi
    fi
    echo
    echo "── socket ──"
    SOCK="$XDG_RUNTIME_DIR/clwnd/clwnd.sock"
    for ext in "" ".hum" ".http"; do
      if [ -S "${SOCK}${ext}" ]; then
        echo "  ${SOCK}${ext}: ok"
      else
        echo "  ${SOCK}${ext}: missing"
      fi
    done
    ;;
  logs)
    IS_ROOT=$([ "$(id -u)" = "0" ] && echo true || echo false)
    OS="$(uname -s)"

    if [ "$OS" = "Darwin" ]; then
      XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
      STDOUT_LOG="$XDG_STATE_HOME/clwnd/daemon.stdout.log"
      STDERR_LOG="$XDG_STATE_HOME/clwnd/daemon.stderr.log"
      # Tell the user up-front what we're going to tail and warn if the
      # files are absent or empty — BSD `tail -f` on a missing file dies
      # fast with a terse error, and on an empty file it just sits there
      # forever showing nothing, neither of which tells you *why*.
      for f in "$STDOUT_LOG" "$STDERR_LOG"; do
        if [ ! -f "$f" ]; then
          echo "  $f: missing (daemon has never written here — run 'clwnd doctor')"
        elif [ ! -s "$f" ]; then
          echo "  $f: empty"
        else
          echo "  $f: $(wc -l < "$f" | tr -d ' ') lines"
        fi
      done
      echo "--- tailing ---"
      # -F (capital) retries on missing files instead of exiting
      tail -F "$STDOUT_LOG" "$STDERR_LOG"
    else
      if $IS_ROOT; then
        journalctl -u clwnd -f
      else
        journalctl --user -u clwnd -f
      fi
    fi
    ;;
  restart)
    IS_ROOT=$([ "$(id -u)" = "0" ] && echo true || echo false)
    SC="systemctl"
    $IS_ROOT || SC="systemctl --user"
    OS="$(uname -s)"

    if [ "$OS" = "Darwin" ]; then
      LABEL="com.clwnd.daemon"
      PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
      launchctl bootout "gui/$(id -u)/${LABEL}" 2>/dev/null || true
      launchctl bootstrap "gui/$(id -u)" "$PLIST"
      echo "restarted"
    else
      $SC restart clwnd
      echo "restarted"
    fi
    ;;
  version)
    cat "$CLWND_SRC/package.json" | grep '"version"' | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/'
    ;;
  sessions)
    XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
    FILE="$XDG_STATE_HOME/clwnd/sessions.json"
    if [ ! -f "$FILE" ]; then echo "no sessions"; exit 0; fi
    cat "$FILE" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    if not d: print('no sessions'); sys.exit(0)
    for sid, s in d.items():
        claude = s.get('claudeSessionId') or '-'
        model = s.get('modelId','?')
        print(f\"  {sid[:30]}  claude={claude[:12]}  model={model}\")
    print(f\"\n{len(d)} session(s)\")
except: print('error reading sessions')
" 2>/dev/null || cat "$FILE"
    ;;
  savings)
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}"
    SOCK="${CLWND_SOCKET:-$XDG_RUNTIME_DIR/clwnd/clwnd.sock}.http"
    if [ ! -S "$SOCK" ]; then
      echo "daemon not running (socket $SOCK not found)"
      exit 1
    fi
    SUB="${1:-}"
    if [ "$SUB" = "reset" ]; then
      curl -s -X POST --unix-socket "$SOCK" http://localhost/savings/reset >/dev/null
      echo "counters reset"
      exit 0
    fi
    curl -s --unix-socket "$SOCK" http://localhost/savings | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    c = d.get('counters', {})
    uptime = d.get('uptimeMs', 0) / 1000
    h = int(uptime // 3600); m = int((uptime % 3600) // 60); s = int(uptime % 60)
    def kb(b):
        if b == 0: return '0'
        if b < 1024: return f'{b}B'
        if b < 1024*1024: return f'{b/1024:.1f}K'
        return f'{b/1024/1024:.2f}M'
    print(f'clwnd savings  (since {h}h {m}m {s}s ago)')
    print()
    print('Daemon-side:')
    print(f'  Read dedup:        {c.get(\"readDedupHits\", 0):>7}  hits   ({kb(c.get(\"readDedupBytes\", 0))} not re-sent)')
    print(f'  Bash cap:          {c.get(\"bashTruncated\", 0):>7}  hits   ({kb(c.get(\"bashBytesTrimmed\", 0))} trimmed)')
    print(f'  Context warning:   {c.get(\"contextOverThreshold\", 0):>7}  prompts where last turn crossed {d.get(\"contextWarnThreshold\", 300000):,} tokens')
    print()
    print('Plugin-side:')
    print(f'  Reminder stripped: {c.get(\"reminderStripped\", 0):>7}')
    print(f'  Hum dedup:         {c.get(\"humDedup\", 0):>7}  prompts skipped ≥1 field')
    print(f'  priorPetals elided:{c.get(\"priorPetalsElided\", 0):>7}')
    top = d.get('topContextSessions', [])
    if top:
        print()
        print('Top context sessions (peak per-turn input):')
        for t in top[:5]:
            print(f'  {t[\"sid\"][:30]:32s}  {t[\"maxContextTokens\"]:,} tokens')
    print()
    print('counters persist across daemon restarts — \\'clwnd savings reset\\' to zero')
except Exception as e:
    print(f'error: {e}')
"
    ;;
  drift)
    SUB="${1:-}"
    if [ "$SUB" = "help" ] || [ "$SUB" = "--help" ] || [ "$SUB" = "-h" ]; then
      cat <<'DRIFTHELP'
clwnd drift — per-bloom latency report (one bloom = one assistant turn)

Usage:
  clwnd drift              Recent blooms + aggregate p50/p95
  clwnd drift <sid>        Filter to one session
  clwnd drift --days N     Read back N days of persisted blooms
  clwnd drift --limit N    Cap rows (default 20)
  clwnd drift help         This help

Phase order (canonical):
  plugin_doStream_enter    plugin's doStream begins (Stage 2)
  plugin_prompt_sent       plugin finished prep, hum'd prompt to daemon
    span plugin_prep       prep cost (graft prep, perm fetch, MCP cfg)
    span hum_hop_outbound  socket hop plugin → daemon
  graft_synced             daemon spliced JSONL from priorPetals
    span graft             splice ms
  nest_spawned             daemon cold-spawned Claude CLI
    span nest_spawn        spawn ms (absent if flag.warm = true)
  murmur                   daemon wrote prompt to Claude stdin
  first_petal              first byte from Claude CLI (TTFB)
  first_reasoning_start    Claude opened a thinking block
    span reasoning         cumulative thinking time
  first_text_start         Claude opened a text block
  first_tool_input_start   Claude picked a tool
    span tool_args:<tool>  args-stream time per tool
  first_uncup              cup released (drone cleared the first bytes)
  first_bloom              first chunk hit the wire
    span hum_hop_inbound   socket hop daemon → plugin (first chunk)
  plugin_first_enqueue     plugin enqueued first text-delta on the AI SDK stream
  plugin_first_visible     == first_enqueue (Stage 3 refinement pending)
  oc_bus_publish           OC processor published first part-delta on the bus
  oc_sse_write             SSE writer flushed (≈ bus_publish, sub-ms)
  wilt                     entire bloom wall-clock (open → wilt)

Spans (cumulative durations, not phase marks):
  reasoning, graft, nest_spawn, plugin_prep, hum_hop_outbound,
  hum_hop_inbound, compaction_curate, permission_check, permission_hold,
  brokered:<tool>, external_mcp_spawn, external_exec:<server>,
  task_subagent, tendril_exec:<tool>, tool_args:<tool>

Flags:
  warm                     daemon reused existing Claude CLI process
  withered                 count of drone-wither retries on this turn

Tendrils: per-MCP tools/call roundtrip (non-permission_prompt only).
  Decompositions live in spans (brokered:*, external_*, task_subagent).

The TUI render gap (SSE → terminal pixels) is OUT of clwnd's process and
unmeasurable from here. The chain ends at oc_sse_write.
DRIFTHELP
      exit 0
    fi
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}"
    SOCK="${CLWND_SOCKET:-$XDG_RUNTIME_DIR/clwnd/clwnd.sock}.http"
    if [ ! -S "$SOCK" ]; then
      echo "daemon not running (socket $SOCK not found)"
      exit 1
    fi
    # Parse remaining args: optional sid, --days N, --limit N
    SID=""
    DAYS=""
    LIMIT="20"
    while [ -n "$SUB" ]; do
      case "$SUB" in
        --days) shift; DAYS="$1" ;;
        --limit) shift; LIMIT="$1" ;;
        *) [ -z "$SID" ] && SID="$SUB" ;;
      esac
      shift
      SUB="${1:-}"
    done
    QUERY="?limit=$LIMIT"
    [ -n "$SID" ] && QUERY="${QUERY}&sid=$SID"
    [ -n "$DAYS" ] && QUERY="${QUERY}&days=$DAYS"
    curl -s --unix-socket "$SOCK" "http://localhost/drift$QUERY" | python3 -c "
import sys, json
def fmt_ms(v):
    if v is None: return '-'
    if v < 1000: return f'{int(v)}ms'
    return f'{v/1000:.2f}s'
def gap(marks, a, b):
    av, bv = marks.get(a), marks.get(b)
    if av is None or bv is None: return None
    return bv - av
try:
    d = json.load(sys.stdin)
    recent = d.get('recent', [])
    agg = d.get('aggregate', {})
    if not recent:
        print('no blooms recorded yet')
    else:
        print(f'{\"sid\":<32}  {\"bloom\":<6} {\"total\":>8} {\"graft\":>8} {\"spawn\":>8} {\"ttfb\":>8} {\"cup\":>8} {\"wire\":>8} flags  tendrils')
        for t in recent[:20]:
            sid = t.get('sid','?')[:30]
            tid = t.get('bloomId', t.get('turnId','?'))
            marks = t.get('marks', {})
            spans = t.get('spans', {})
            flags = t.get('flags', {})
            total = marks.get('wilt', marks.get('bloom', marks.get('turn')))
            graft = spans.get('graft')
            spawn = spans.get('nest_spawn')
            ttfb = gap(marks, 'murmur', 'first_petal')
            cup = gap(marks, 'first_petal', 'first_uncup')
            bloom = gap(marks, 'first_uncup', 'first_bloom')
            flag_str = ''
            if flags.get('warm'): flag_str += 'W'
            wc = flags.get('withered', 0)
            if wc: flag_str += f'×{wc}'
            tendrils = t.get('tendrils', [])
            tend_str = ' '.join(f'{x[\"name\"]}:{fmt_ms(x[\"ms\"])}' for x in tendrils[:5])
            if len(tendrils) > 5: tend_str += f' (+{len(tendrils)-5})'
            print(f'{sid:<32}  {tid:<6} {fmt_ms(total):>8} {fmt_ms(graft):>8} {fmt_ms(spawn):>8} {fmt_ms(ttfb):>8} {fmt_ms(cup):>8} {fmt_ms(bloom):>8} {flag_str:<5}  {tend_str}')
        marks = agg.get('marks', {})
        print()
        print(f'aggregate (last {agg.get(\"blooms\",agg.get(\"turns\",0))} blooms)')
        print(f'  {\"mark\":<24} {\"p50\":>8} {\"p95\":>8} {\"n\":>5}')
        mark_order = ['graft_synced','nest_spawned','murmur','first_petal','first_reasoning_start','first_text_start','first_tool_input_start','first_uncup','first_bloom','wilt']
        for name in mark_order:
            s = marks.get(name)
            if not s: continue
            print(f'  {name:<24} {fmt_ms(s[\"p50\"]):>8} {fmt_ms(s[\"p95\"]):>8} {s[\"n\"]:>5}')
        spans_agg = agg.get('spans', {})
        if spans_agg:
            print()
            print(f'  {\"span\":<24} {\"p50\":>8} {\"p95\":>8} {\"n\":>5}')
            for name, s in sorted(spans_agg.items(), key=lambda kv: -kv[1]['p95']):
                print(f'  {name:<24} {fmt_ms(s[\"p50\"]):>8} {fmt_ms(s[\"p95\"]):>8} {s[\"n\"]:>5}')
        tendrils = agg.get('tendrils', {})
        if tendrils:
            print()
            print('  tendril latency (p50/p95):')
            for name, s in sorted(tendrils.items(), key=lambda kv: -kv[1]['p95'])[:10]:
                print(f'    {name:<32} {fmt_ms(s[\"p50\"]):>8} {fmt_ms(s[\"p95\"]):>8} {s[\"n\"]:>5}')
except Exception as e:
    print(f'error: {e}')
"
    ;;
  help|--help|-h|"")
    echo "clwnd - take back what is yours"
    echo ""
    echo "Usage: clwnd <command>"
    echo ""
    echo "Commands:"
    echo "  update     Pull latest, rebuild, restart daemon"
    echo "  force      Fresh install from remote (bypasses cache)"
    echo "  restart    Restart the daemon"
    echo "  status     Show daemon status"
    echo "  doctor     Full diagnostic probe (process, port, service, socket)"
    echo "  logs       Tail daemon logs"
    echo "  sessions   List tracked sessions"
    echo "  savings    Show penny-pincher counters (read dedup, bash cap, context warning, plugin-side dedup)"
    echo "  drift      Per-bloom latency report — phase breakdowns and tendril roundtrips"
    echo "  version    Show installed version"
    echo "  uninstall  Remove clwnd"
    ;;
  *)
    echo "Unknown command: $CMD"
    echo "Run 'clwnd help' for usage."
    exit 1
    ;;
esac
