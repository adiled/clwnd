#!/usr/bin/env bash
set -e

XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
CLWND_SRC="$XDG_DATA_HOME/clwnd/src"

if [ ! -d "$CLWND_SRC" ]; then
  echo "clwnd not installed. Run:"
  echo "  curl -fsSL https://raw.githubusercontent.com/adiled/clwnd/main/install | bash"
  exit 1
fi

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  update)
    exec bash -c "$(curl -fsSL "https://raw.githubusercontent.com/adiled/clwnd/main/install?t=$(date +%s)")" -- update
    ;;
  force)
    exec bash -c "$(curl -fsSL "https://raw.githubusercontent.com/adiled/clwnd/main/install?t=$(date +%s)")" -- install
    ;;
  uninstall)
    exec bash -c "$(curl -fsSL "https://raw.githubusercontent.com/adiled/clwnd/main/install?t=$(date +%s)")" -- uninstall
    ;;
  status)
    IS_ROOT=$([ "$(id -u)" = "0" ] && echo true || echo false)
    SC="systemctl"
    $IS_ROOT || SC="systemctl --user"
    OS="$(uname -s)"

    if [ "$OS" = "Darwin" ]; then
      launchctl print "gui/$(id -u)/com.clwnd.daemon" 2>/dev/null | head -5 || echo "daemon not running"
    else
      $SC status clwnd 2>/dev/null | head -5 || echo "daemon not running"
    fi
    ;;
  logs)
    IS_ROOT=$([ "$(id -u)" = "0" ] && echo true || echo false)
    OS="$(uname -s)"

    if [ "$OS" = "Darwin" ]; then
      XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
      tail -f "$XDG_STATE_HOME/clwnd/daemon.stdout.log" "$XDG_STATE_HOME/clwnd/daemon.stderr.log"
    else
      if $IS_ROOT; then
        journalctl -u clwnd -f
      else
        journalctl --user -u clwnd -f
      fi
    fi
    ;;
  restart)
    IS_ROOT=$([ "$(id -u)" = "0" ] && echo true || echo false)
    SC="systemctl"
    $IS_ROOT || SC="systemctl --user"
    OS="$(uname -s)"

    if [ "$OS" = "Darwin" ]; then
      LABEL="com.clwnd.daemon"
      PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
      launchctl bootout "gui/$(id -u)/${LABEL}" 2>/dev/null || true
      launchctl bootstrap "gui/$(id -u)" "$PLIST"
      echo "restarted"
    else
      $SC restart clwnd
      echo "restarted"
    fi
    ;;
  version)
    cat "$CLWND_SRC/package.json" | grep '"version"' | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/'
    ;;
  sessions)
    XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
    FILE="$XDG_STATE_HOME/clwnd/sessions.json"
    if [ ! -f "$FILE" ]; then echo "no sessions"; exit 0; fi
    cat "$FILE" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    if not d: print('no sessions'); sys.exit(0)
    for sid, s in d.items():
        claude = s.get('claudeSessionId') or '-'
        model = s.get('modelId','?')
        print(f\"  {sid[:30]}  claude={claude[:12]}  model={model}\")
    print(f\"\n{len(d)} session(s)\")
except: print('error reading sessions')
" 2>/dev/null || cat "$FILE"
    ;;
  savings)
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}"
    SOCK="${CLWND_SOCKET:-$XDG_RUNTIME_DIR/clwnd/clwnd.sock}.http"
    if [ ! -S "$SOCK" ]; then
      echo "daemon not running (socket $SOCK not found)"
      exit 1
    fi
    curl -s --unix-socket "$SOCK" http://localhost/savings | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    c = d.get('counters', {})
    uptime = d.get('uptimeMs', 0) / 1000
    h = int(uptime // 3600); m = int((uptime % 3600) // 60); s = int(uptime % 60)
    def kb(b): return f'{b/1024:.1f}K' if b < 1024*1024 else f'{b/1024/1024:.2f}M'
    print(f'clwnd savings  (daemon uptime {h}h {m}m {s}s)')
    print()
    print('Read dedup:')
    print(f'  hits:              {c.get(\"readDedupHits\", 0)}')
    print(f'  bytes not re-sent: {kb(c.get(\"readDedupBytes\", 0))}')
    print()
    print('Bash output cap:')
    print(f'  truncated calls:   {c.get(\"bashTruncated\", 0)}')
    print(f'  bytes trimmed:     {kb(c.get(\"bashBytesTrimmed\", 0))}')
    print()
    print('Context rotation:')
    print(f'  threshold:         {d.get(\"rotateThreshold\", 300000):,} tokens')
    print(f'  turns over:        {c.get(\"contextOverThreshold\", 0)}')
    print(f'  rotations fired:   {c.get(\"rotations\", 0)}')
    top = d.get('topContextSessions', [])
    if top:
        print()
        print('Top context sessions (peak per-turn input):')
        for t in top[:5]:
            print(f'  {t[\"sid\"][:30]:32s}  {t[\"maxContextTokens\"]:,} tokens')
    print()
    print('(plugin-side dedup events — system-reminder strip, hum field hash,')
    print(' priorPetals elision, aux model routing — live in the plugin process.')
    print(' Grep journal for: reminder.stripped, hum.dedup, priorPetals.elided,')
    print(' aux.model.routed.)')
except Exception as e:
    print(f'error: {e}')
"
    ;;
  help|--help|-h|"")
    echo "clwnd - take back what is yours"
    echo ""
    echo "Usage: clwnd <command>"
    echo ""
    echo "Commands:"
    echo "  update     Pull latest, rebuild, restart daemon"
    echo "  force      Fresh install from remote (bypasses cache)"
    echo "  restart    Restart the daemon"
    echo "  status     Show daemon status"
    echo "  logs       Tail daemon logs"
    echo "  sessions   List tracked sessions"
    echo "  savings    Show penny-pincher counters (read dedup, bash cap, rotations)"
    echo "  version    Show installed version"
    echo "  uninstall  Remove clwnd"
    ;;
  *)
    echo "Unknown command: $CMD"
    echo "Run 'clwnd help' for usage."
    exit 1
    ;;
esac
